# Runtime; public values may be copied to browser builds only when prefixed NEXT_PUBLIC_.
BINNAGENT_ENV=development
BINNAGENT_LOG_LEVEL=INFO
BINNAGENT_TIMEZONE=Asia/Shanghai

# PostgreSQL; secret, server-only. Replace locally and never commit a real credential.
BINNAGENT_DATABASE_URL=postgresql+asyncpg://binnagent:binnagent_dev_only@localhost:5432/binnagent
POSTGRES_DB=binnagent
POSTGRES_USER=binnagent
POSTGRES_PASSWORD=binnagent_dev_only

# Learner login. `session` enables email OTP + HttpOnly cookie sessions.
# For local migration, unset values can be read from ../BinnAgent/.env using legacy BINN_* names.
BINNAGENT_LEARNER_IDENTITY_ADAPTER=session
BINNAGENT_CONTROL_IDENTITY_ADAPTER=synthetic
BINNAGENT_CONTROL_REQUIRED_ROLE=developer_reviewer
BINNAGENT_SESSION_COOKIE_NAME=binnagent_session
BINNAGENT_SESSION_TTL_SECONDS=2592000
BINNAGENT_BOOTSTRAP_INVITE_CODE=BINN-LOCAL-FIRST
BINNAGENT_EMAIL_VERIFICATION_SECRET=local-email-verification-secret-change-me
BINNAGENT_EXPERIENCE_CODE_SECRET=local-experience-code-secret-change-me
BINNAGENT_EMAIL_VERIFICATION_CODE_TTL_SECONDS=600
BINNAGENT_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=600
BINNAGENT_EMAIL_VERIFICATION_RESEND_SECONDS=60
BINNAGENT_EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Use console only for local development. Production requires SMTP and real secrets.
BINNAGENT_EMAIL_DELIVERY_MODE=console
BINNAGENT_SMTP_HOST=
BINNAGENT_SMTP_PORT=587
BINNAGENT_SMTP_USERNAME=
BINNAGENT_SMTP_PASSWORD=
BINNAGENT_SMTP_FROM_ADDRESS=no-reply@binnagent.local
BINNAGENT_SMTP_STARTTLS=true
BINNAGENT_SMTP_USE_SSL=false

# Model gateway. auto prefers a configured credential-backed provider, then local Ollama.
# deterministic_fixture is retained only for explicit offline/testing use and safe fallback.
# BINN_MODEL_PROVIDER and the matching BINN_* provider settings from ../BinnAgent/.env are accepted.
BINNAGENT_MODEL_ADAPTER=auto
BINNAGENT_ENABLE_REMOTE_MODEL_CALLS=true
BINNAGENT_MODEL_TIMEOUT_SECONDS=20
BINNAGENT_MODEL_MAX_CALLS_PER_SLICE=3
BINNAGENT_MODEL_MAX_COST_USD_PER_SLICE=0.20
BINNAGENT_MODEL_ESTIMATED_COST_USD=0.02
BINNAGENT_MODEL_MAX_TOKENS=900
BINNAGENT_CONTENT_GENERATION_TIMEOUT_SECONDS=180
BINNAGENT_CONTENT_GENERATION_MAX_TOKENS=16000
BINNAGENT_CONTENT_REVIEW_TIMEOUT_SECONDS=180
BINNAGENT_CONTENT_REVIEW_MAX_TOKENS=8000
BINNAGENT_OLLAMA_BASE_URL=http://localhost:11434
# Container-only override; the default reaches Ollama on the Docker host.
BINNAGENT_DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
BINNAGENT_OLLAMA_CHAT_MODEL=gemma4:e2b
BINNAGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
BINNAGENT_DEEPSEEK_API_KEY=
BINNAGENT_DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
BINNAGENT_LONGCAT_BASE_URL=https://api.longcat.chat/openai
BINNAGENT_LONGCAT_API_KEY=
BINNAGENT_LONGCAT_CHAT_MODEL=LongCat-2.0

# Agent observability. BinnAgentX also reads the sibling BinnAgent .env, so the
# existing local Langfuse project can be shared without copying its credentials.
BINNAGENT_LANGFUSE_ENABLED=false
BINNAGENT_LANGFUSE_PUBLIC_KEY=
BINNAGENT_LANGFUSE_SECRET_KEY=
BINNAGENT_LANGFUSE_BASE_URL=http://localhost:3100
BINNAGENT_LANGFUSE_EXTERNAL_URL=http://localhost:3100
BINNAGENT_LANGFUSE_ENVIRONMENT=development

# Prefect handles task dispatch and worker/run visibility only. Content approval
# and publishing remain authoritative in the BinnAgentX database.
BINNAGENT_PREFECT_ENABLED=true
BINNAGENT_PREFECT_API_URL=http://localhost:4200/api
BINNAGENT_PREFECT_EXTERNAL_URL=http://localhost:4200

# Content and feature gates.
BINNAGENT_CONTENT_MANIFEST=fixtures/content/v1/manifest.json
BINNAGENT_MIN_CONTENT_RIGHTS_STATUS=eligible_dev
BINNAGENT_ENABLE_IRT_CAT=false
BINNAGENT_ENABLE_AUTOMATIC_TOTAL_SCORE=false
BINNAGENT_ENABLE_PREDICTED_SCORE_GAIN=false

# Local browser URLs; public, non-secret.
NEXT_PUBLIC_LEARNER_API_BASE_URL=http://localhost:8000/learner
NEXT_PUBLIC_CONTROL_API_BASE_URL=http://localhost:8000/control

# Telemetry; endpoint may be empty in local development. Never put credentials here.
OTEL_SERVICE_NAME=binnagent-local
OTEL_EXPORTER_OTLP_ENDPOINT=
